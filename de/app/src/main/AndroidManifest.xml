            </intent-filter>
        </activity>
        <activity android:name=".CollegeActivity" />
        <activity android:name=".OfficerActivity" />
        <activity android:name=".StudentActivity" />
        <activity android:name=".JobActivity" />
        <activity android:name=".CompanyActivity" />
        <activity android:name=".ApplicationActivity" />
    </application>

</manifest>
